type: flying
name: Twinkle
description: "A specialized core unit. Completely ignored by enemies. Capable of mining, building, and repairing structures."
flying: true
health: 220
rotateSpeed: 11

# ПРИВИД
targetable: false
hittable: false


# РОБОТА
