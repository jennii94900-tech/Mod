  ochpoch-mob-aluminum
  ochpoch-mob-cristal
]

weapons: [
  {
    type: RepairBeamWeapon
    widthSinMag: 0.1
    x: 2.2
    y: 4
    laserColor: 617CFFFF
    mirror: true
    rotate: false
    targetBuildings: true
    targetUnits: false
    autoTarget: false
    controllable: true
    reload: 20
    repairSpeed: 3.5
    fractionRepairSpeed: 0.06
    bullet: {
      type: BulletType
      # ЗРОБЛЕНО МЕНШИМ: Було 60, тепер 40 (промінь став коротшим)
      maxRange: 40
    }
  }
]

# ШТУЧНИЙ ІНТЕЛЕКТ
controller: RepairAI

# ФІЗИКА ТА ЕФЕКТИ СЛІДУ
