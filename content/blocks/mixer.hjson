type: GenericCrafter
name: "Aluminum Purifier"
description: "Потужна лінія очищення. Переробляє великі партії алюмінію у високоякісний очищений метал за допомогою високих температур."
size: 2 
health: 850
hasPower: true
hasItems: true
itemCapacity: 60 

craftTime: 120 

consumes: {
  power: 4.5 
  items: {
    items: [
      ochpoch-mob-aluminum/6
    ]
  }
}

outputItem: ochpoch-mob-refined-aluminum/5

requirements: [
  ochpoch-mob-aluminum/46
]

category: crafting
research: aluminum

drawer: {
  type: DrawMulti
  drawers: [
    {
      type: DrawDefault
    }
    {
      type: DrawFlame
      // ВИПРАВЛЕНО: Для DrawFlame використовується 'flameColor', а не просто 'color'
      flameColor: 76958EFF
    }
    {
      type: DrawGlowRegion
      suffix: "-glow"
      color: 8FADA6FF
    }
  ]
}

